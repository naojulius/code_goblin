text = "// Initialisation du script
namespace Paysant;

/* Ce gros bloc de commentaire 
   ne doit pas se retrouver 
   dans la console Godot !
*/
public class Paysant : Unit 
{
    public void Run() 
    {
        unit.Gather(); // Récolter l'or
        unit.Deposit(); /* Déposer à l'auberge */
    }
}"
